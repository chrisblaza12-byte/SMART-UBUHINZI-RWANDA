# Copy this file to .env.local in a DOWNLOADED project, then replace the two
# placeholder values from Back4App > App Settings > Security & Keys.
# Do not put your Master Key in any VITE_ variable.
VITE_PARSE_APP_ID=YOUR_REAL_APPLICATION_ID
VITE_PARSE_JAVASCRIPT_KEY=YOUR_REAL_JAVASCRIPT_KEY
VITE_PARSE_SERVER_URL=https://parseapi.back4app.com/parse